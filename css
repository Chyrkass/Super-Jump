    <style>
        :root {
            --bg: #f8f9fc;
            --surface: #ffffff;
            --text: #1a1a2e;
            --text-secondary: #4a4a5e;
            --primary: #1e3a5f;
            --primary-light: #2c5282;
            --accent: #f6c23e;
            --accent-glow: #fbbf24;
            --dark: #0f0f1a;
            --card-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
            --border: #e2e8f0;
            --header-bg: rgba(255, 255, 255, 0.92);
            --gradient-hero: linear-gradient(135deg, #1e3a5f 0%, #0f0f1a 40%, #1a2744 100%);
            --badge-bg: #fef3c7;
            --badge-text: #92400e;
            --review-card: #ffffff;
            --input-bg: #f1f5f9;
            --input-border: #cbd5e1;
            --section-alt: #f1f5f9;
            --modal-overlay: rgba(0, 0, 0, 0.6);
            --success: #059669;
        }

        [data-theme="dark"] {
            --bg: #0f0f1a;
            --surface: #1a1a2e;
            --text: #e8e8f0;
            --text-secondary: #b0b0c0;
            --primary: #3b82f6;
            --primary-light: #60a5fa;
            --accent: #f6c23e;
            --accent-glow: #fbbf24;
            --dark: #e8e8f0;
            --card-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
            --border: #2d2d44;
            --header-bg: rgba(15, 15, 26, 0.94);
            --gradient-hero: linear-gradient(135deg, #0f0f1a 0%, #1a2744 40%, #0f0f1a 100%);
            --badge-bg: #3d2e0a;
            --badge-text: #fcd34d;
            --review-card: #1e1e32;
            --input-bg: #1e1e32;
            --input-border: #3d3d58;
            --section-alt: #141428;
            --modal-overlay: rgba(0, 0, 0, 0.75);
            --success: #10b981;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Segoe UI', 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            line-height: 1.6;
            transition: background-color 0.35s ease, color 0.35s ease;
            overflow-x: hidden;
        }

        /* ===== HEADER ===== */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background: var(--header-bg);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border);
            transition: all 0.35s ease;
            padding: 0 20px;
        }

        .header.scrolled {
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
        }

        .header__inner {
            max-width: 1280px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 68px;
            gap: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            flex-shrink: 0;
        }

        .logo__icon {
            width: 44px;
            height: 44px;
            background: var(--accent);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 20px;
            color: #0f0f1a;
            letter-spacing: -1px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            box-shadow: 0 4px 14px rgba(246, 194, 62, 0.45);
        }

        .logo:hover .logo__icon {
            transform: scale(1.08) rotate(-5deg);
            box-shadow: 0 6px 22px rgba(246, 194, 62, 0.6);
        }

        .logo__text {
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--text);
            letter-spacing: -0.3px;
            white-space: nowrap;
        }
        .logo__text span {
            color: var(--accent);
        }

        .nav {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .nav__link {
            text-decoration: none;
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 0.88rem;
            padding: 8px 14px;
            border-radius: 20px;
            transition: all 0.25s ease;
            white-space: nowrap;
            position: relative;
        }

        .nav__link:hover,
        .nav__link.active {
            color: var(--primary-light);
            background: rgba(59, 130, 246, 0.08);
        }

        .nav__link--accent {
            background: var(--accent) !important;
            color: #0f0f1a !important;
            font-weight: 700;
            padding: 10px 20px;
            border-radius: 24px;
            box-shadow: 0 4px 16px rgba(246, 194, 62, 0.35);
            transition: all 0.3s ease;
        }

        .nav__link--accent:hover {
            box-shadow: 0 6px 24px rgba(246, 194, 62, 0.55);
            transform: translateY(-2px);
        }

        /* Theme toggle */
        .theme-toggle {
            background: var(--surface);
            border: 2px solid var(--border);
            border-radius: 30px;
            width: 50px;
            height: 28px;
            cursor: pointer;
            position: relative;
            transition: all 0.35s ease;
            flex-shrink: 0;
            margin-left: 4px;
        }
        .theme-toggle::after {
            content: '☀️';
            position: absolute;
            top: 2px;
            left: 3px;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            transition: all 0.35s ease;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
        }
        [data-theme="dark"] .theme-toggle::after {
            content: '🌙';
            left: 23px;
            background: #3b82f6;
        }

        /* Mobile burger */
        .burger {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            flex-direction: column;
            gap: 5px;
            padding: 8px;
            z-index: 1001;
        }
        .burger span {
            display: block;
            width: 26px;
            height: 3px;
            background: var(--text);
            border-radius: 3px;
            transition: all 0.3s ease;
        }
        .burger.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 6px);
        }
        .burger.active span:nth-child(2) {
            opacity: 0;
        }
        .burger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -6px);
        }

        /* ===== SECTIONS ===== */
        .section {
            padding: 90px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section--hero {
            padding-top: 140px;
            padding-bottom: 100px;
            max-width: 100%;
            background: var(--gradient-hero);
            color: #f1f5f9;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .section--hero::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -80px;
            width: 380px;
            height: 380px;
            background: radial-gradient(circle, rgba(246, 194, 62, 0.25) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        .section--hero::after {
            content: '';
            position: absolute;
            bottom: -80px;
            left: -60px;
            width: 340px;
            height: 340px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.3) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        .hero__inner {
            max-width: 800px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }
        .hero__badge {
            display: inline-block;
            background: var(--accent);
            color: #0f0f1a;
            font-weight: 700;
            padding: 6px 18px;
            border-radius: 20px;
            font-size: 0.85rem;
            letter-spacing: 0.4px;
            margin-bottom: 20px;
        }
        .hero__title {
            font-size: 3rem;
            font-weight: 900;
            letter-spacing: -1px;
            margin-bottom: 16px;
            line-height: 1.15;
        }
        .hero__title span {
            color: var(--accent);
        }
        .hero__subtitle {
            font-size: 1.2rem;
            opacity: 0.85;
            margin-bottom: 36px;
            max-width: 550px;
            margin-left: auto;
            margin-right: auto;
        }
        .btn {
            display: inline-block;
            padding: 14px 32px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 1rem;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
            letter-spacing: 0.3px;
        }
        .btn--accent {
            background: var(--accent);
            color: #0f0f1a;
            box-shadow: 0 6px 22px rgba(246, 194, 62, 0.4);
        }
        .btn--accent:hover {
            box-shadow: 0 10px 30px rgba(246, 194, 62, 0.55);
            transform: translateY(-3px);
        }
        .btn--outline {
            background: transparent;
            border: 2px solid #f1f5f9;
            color: #f1f5f9;
            margin-left: 12px;
        }
        .btn--outline:hover {
            background: #f1f5f9;
            color: #0f0f1a;
        }
        .btn--dark {
            background: var(--primary);
            color: #fff;
            box-shadow: 0 6px 20px rgba(30, 58, 95, 0.4);
        }
        .btn--dark:hover {
            box-shadow: 0 10px 28px rgba(30, 58, 95, 0.55);
            transform: translateY(-3px);
        }

        /* ===== ABOUT ===== */
        .section__title {
            font-size: 2.2rem;
            font-weight: 900;
            text-align: center;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }
        .section__subtitle {
            text-align: center;
            color: var(--text-secondary);
            margin-bottom: 50px;
            font-size: 1.05rem;
        }
        .about-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 28px;
        }
        .about-card {
            background: var(--surface);
            border-radius: 20px;
            padding: 32px 24px;
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            text-align: center;
        }
        .about-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.14);
        }
        .about-card__icon {
            font-size: 2.6rem;
            margin-bottom: 14px;
        }
        .about-card__title {
            font-weight: 800;
            font-size: 1.15rem;
            margin-bottom: 8px;
            color: var(--primary-light);
        }

        /* ===== REVIEWS ===== */
        .reviews-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
        }
        .review-card {
            background: var(--review-card);
            border-radius: 20px;
            padding: 28px 24px;
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border);
            transition: transform 0.3s ease;
        }
        .review-card:hover {
            transform: translateY(-4px);
        }
        .review-card__stars {
            color: var(--accent);
            font-size: 1.1rem;
            margin-bottom: 10px;
        }
        .review-card__text {
            font-style: italic;
            color: var(--text-secondary);
            margin-bottom: 14px;
        }
        .review-card__author {
            font-weight: 700;
            color: var(--primary-light);
        }

        /* ===== GIFT ===== */
        .gift-box {
            background: var(--surface);
            border: 2px dashed var(--accent);
            border-radius: 24px;
            padding: 50px 30px;
            text-align: center;
            max-width: 650px;
            margin: 0 auto;
            box-shadow: var(--card-shadow);
            position: relative;
        }
        .gift-box__icon {
            font-size: 4rem;
            margin-bottom: 16px;
        }
        .gift-box__title {
            font-weight: 900;
            font-size: 1.6rem;
            margin-bottom: 10px;
        }
        .gift-form {
            display: flex;
            gap: 10px;
            max-width: 420px;
            margin: 20px auto 0;
            flex-wrap: wrap;
            justify-content: center;
        }
        .gift-form input {
            flex: 1 1 220px;
            padding: 14px 18px;
            border-radius: 28px;
            border: 2px solid var(--input-border);
            background: var(--input-bg);
            font-size: 1rem;
            color: var(--text);
            outline: none;
            transition: border 0.3s ease;
        }
        .gift-form input:focus {
            border-color: var(--accent);
        }
        .gift-form button {
            flex-shrink: 0;
        }

        /* ===== TEST ===== */
        .test-box {
            background: var(--surface);
            border-radius: 24px;
            padding: 40px 30px;
            max-width: 650px;
            margin: 0 auto;
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border);
            text-align: center;
        }
        .test-question {
            font-weight: 700;
            font-size: 1.2rem;
            margin-bottom: 20px;
        }
        .test-options {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin-bottom: 20px;
        }
        .test-option {
            padding: 12px 22px;
            border-radius: 24px;
            border: 2px solid var(--border);
            background: var(--input-bg);
            cursor: pointer;
            font-weight: 600;
            transition: all 0.25s ease;
            color: var(--text);
        }
        .test-option:hover,
        .test-option.selected {
            border-color: var(--accent);
            background: var(--badge-bg);
            color: var(--badge-text);
        }
        .test-result {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--success);
            min-height: 30px;
            margin-top: 10px;
        }

        /* ===== LIBRARY ===== */
        .library-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }
        .library-item {
            background: var(--surface);
            border-radius: 16px;
            padding: 24px 18px;
            text-align: center;
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border);
            transition: transform 0.3s ease;
            cursor: pointer;
        }
        .library-item:hover {
            transform: translateY(-5px);
        }
        .library-item__icon {
            font-size: 2.8rem;
            margin-bottom: 10px;
        }
        .library-item__title {
            font-weight: 700;
            color: var(--primary-light);
        }

        /* ===== FOOTER ===== */
        .footer {
            background: var(--dark-bg, #0f0f1a);
            color: #b0b0c0;
            text-align: center;
            padding: 30px 20px;
            font-size: 0.9rem;
            border-top: 1px solid var(--border);
        }
        [data-theme="dark"] .footer {
            background: #08081a;
        }
        [data-theme="light"] .footer {
            background: #1a1a2e;
            color: #c0c0d0;
        }

        /* ===== BACK TO TOP ===== */
        .back-to-top {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--accent);
            color: #0f0f1a;
            border: none;
            cursor: pointer;
            font-size: 1.4rem;
            font-weight: 900;
            box-shadow: 0 6px 22px rgba(246, 194, 62, 0.45);
            z-index: 999;
            opacity: 0;
            transform: translateY(20px);
            pointer-events: none;
            transition: all 0.35s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .back-to-top.visible {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }
        .back-to-top:hover {
            box-shadow: 0 10px 28px rgba(246, 194, 62, 0.6);
            transform: translateY(-4px) scale(1.05);
        }

        /* ===== MODAL ===== */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--modal-overlay);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        .modal.active {
            opacity: 1;
            pointer-events: auto;
        }
        .modal__content {
            background: var(--surface);
            border-radius: 24px;
            padding: 40px 30px;
            max-width: 480px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
            position: relative;
        }
        .modal__close {
            position: absolute;
            top: 14px;
            right: 18px;
            background: none;
            border: none;
            font-size: 1.6rem;
            cursor: pointer;
            color: var(--text-secondary);
            transition: color 0.2s;
        }
        .modal__close:hover {
            color: var(--text);
        }
        .modal__title {
            font-weight: 900;
            font-size: 1.5rem;
            margin-bottom: 8px;
        }
        .modal__input {
            width: 100%;
            padding: 14px 18px;
            border-radius: 28px;
            border: 2px solid var(--input-border);
            background: var(--input-bg);
            font-size: 1rem;
            color: var(--text);
            outline: none;
            margin: 10px 0;
            transition: border 0.3s;
        }
        .modal__input:focus {
            border-color: var(--accent);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 900px) {
            .burger {
                display: flex;
            }
            .nav {
                position: fixed;
                top: 0;
                right: -320px;
                width: 280px;
                height: 100vh;
                background: var(--surface);
                flex-direction: column;
                padding: 90px 24px 30px;
                gap: 6px;
                box-shadow: -8px 0 30px rgba(0, 0, 0, 0.2);
                transition: right 0.35s ease;
                align-items: stretch;
                z-index: 999;
                border-left: 1px solid var(--border);
            }
            .nav.active {
                right: 0;
            }
            .nav__link {
                display: block;
                text-align: center;
                padding: 12px 16px;
                font-size: 1rem;
            }
            .hero__title {
                font-size: 2rem;
            }
            .hero__subtitle {
                font-size: 1rem;
            }
            .btn--outline {
                margin-left: 0;
                margin-top: 10px;
            }
            .section {
                padding: 60px 16px;
            }
            .section--hero {
                padding-top: 120px;
                padding-bottom: 70px;
            }
            .gift-form {
                flex-direction: column;
                align-items: center;
            }
            .gift-form input {
                width: 100%;
            }
        }

        @media (max-width: 480px) {
            .header__inner {
                height: 58px;
            }
            .logo__text {
                font-size: 0.95rem;
            }
            .logo__icon {
                width: 34px;
                height: 34px;
                font-size: 16px;
            }
            .hero__title {
                font-size: 1.6rem;
            }
            .section__title {
                font-size: 1.6rem;
            }
            .back-to-top {
                bottom: 16px;
                right: 16px;
                width: 40px;
                height: 40px;
                font-size: 1.2rem;
            }
        }
    </style>
